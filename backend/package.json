{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "start": "bun run src/main.ts",
    "build": "bun run scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "test": "bun test",
    "test:e2e": "bun test test/e2e",
    "smoke:svg": "bun run scripts/smoke-svg.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11",
    "@fastify/multipart": "^9",
    "@fastify/static": "^8",
    "@nestjs/common": "^11",
    "@nestjs/config": "^4",
    "@nestjs/core": "^11",
    "@nestjs/platform-fastify": "^11",
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "fastify": "^5.8.5",
    "jsonwebtoken": "^9.0.2",
    "lunar-typescript": "^1.8.6",
    "nestjs-pino": "^4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2",
    "rxjs": "^7.8.0",
    "shared": "workspace:*",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.6.2",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0"
  }
