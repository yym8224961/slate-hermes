# ── 运行环境 ──────────────────────────────────────
NODE_ENV=development                     # development | production | test
LOG_LEVEL=info                           # debug | info | warn | error
PORT=3001

# ── 数据库 ────────────────────────────────────────
# MySQL 8 连接串，格式: mysql://user:pwd@host:3306/db

# 本地快速启动:
#   docker run -d --name slate-mysql -p 3306:3306 \
#     -e MYSQL_ROOT_PASSWORD=root -e MYSQL_DATABASE=slate \
#     -e MYSQL_USER=slate -e MYSQL_PASSWORD=slate mysql:8
DATABASE_URL=mysql://slate:slate@127.0.0.1:3306/slate
# 仅在 MySQL 使用 caching_sha2_password 且没有配置 TLS/固定公钥时需要。
# 本地 Docker MySQL 通常需要 true；外部生产 MySQL 建议配置 TLS 或固定公钥后改为 false。
DB_ALLOW_PUBLIC_KEY_RETRIEVAL=true

# ── 认证 ──────────────────────────────────────────
# ≥ 32 字符，生产环境务必替换: openssl rand -hex 64
JWT_SECRET=dev_only_change_in_production_32chars
JWT_EXPIRATION=7d

# ── 存储 ──────────────────────────────────────────
BLOB_DIR=./blobs                         # docker 镜像内固定 /data/blobs

# ── 天气（动态帧）──────────────────────────────────
# QWeather 控制台创建 API KEY 后，还需要在「设置」里复制 API Host。
# 不配置时天气动态帧会显示上次缓存数据或报配置缺失。
QWEATHER_API_KEY=
QWEATHER_API_HOST=

# ── AI / TTS ──────────────────────────────────────
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=gpt-4o-mini
TTS_API_KEY=
TTS_BASE_URL=
TTS_MODEL=mimo-v2.5-tts
TTS_DEFAULT_VOICE=冰糖

# ── 后台任务 ───────────────────────────────────────
BACKGROUND_WORKERS=true
