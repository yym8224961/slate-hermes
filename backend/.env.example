# ── 运行环境 ──────────────────────────────────────
NODE_ENV=development                     # development | production | test
LOG_LEVEL=info                           # debug | info | warn | error
PORT=3001

# ── 数据库 ────────────────────────────────────────
# MySQL 8 连接串，格式: mysql://user:pwd@host:3306/db

# 本地快速启动:
#   docker run -d --name slate-mysql -p 3306:3306 \
#     -e MYSQL_ROOT_PASSWORD=root -e MYSQL_DATABASE=slate \
#     -e MYSQL_USER=slate -e MYSQL_PASSWORD=slate mysql:8
DATABASE_URL=mysql://slate:slate@127.0.0.1:3306/slate

# ── 认证 ──────────────────────────────────────────
# ≥ 16 字符，生产环境务必替换: openssl rand -hex 64
JWT_SECRET=dev_only_change_in_production
JWT_EXPIRATION=7d

# ── 存储 ──────────────────────────────────────────
BLOB_DIR=./blobs                         # docker 镜像内固定 /data/blobs
