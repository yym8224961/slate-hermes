# MySQL:测试机直连(参考 quant 同款,LAN 192.168.31.12,不用 docker)
# 测试机上提前 mysql -uroot 建库 + 建用户:
#   CREATE DATABASE slate CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#   CREATE USER 'slate'@'%' IDENTIFIED BY '<your-strong-pwd>';
#   GRANT ALL ON slate.* TO 'slate'@'%';
#   FLUSH PRIVILEGES;
DATABASE_URL=mysql://slate:<your-pwd>@192.168.31.12:3306/slate

# Backend 监听端口
PORT=3001

# JWT secret,正式部署用 openssl rand -hex 64
JWT_SECRET=dev_only_change_in_production
JWT_EXPIRATION=7d

# 看板 webhook API key("其他项目"调用 /webhook/groups/{id}/render 用)
WEBHOOK_API_KEY=dev_only_change_in_production_three

# Blob 存储目录(frame image + audio 二进制)
BLOB_DIR=./blobs

# 设备拉取轮询间隔(秒),下发给设备
DEVICE_POLL_INTERVAL_SECONDS=60

# CORS allow origin(前端 dev server)
CORS_ORIGIN=http://localhost:5173

# 运行环境(development | production | test)
NODE_ENV=development

# 日志级别(debug | info | warn | error)
LOG_LEVEL=info
