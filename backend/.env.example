# 数据库连接。任意可达的 MySQL 8 实例。
# 本地起一个最小 MySQL:
#   docker run -d --name slate-mysql -p 3306:3306 \
#     -e MYSQL_ROOT_PASSWORD=root \
#     -e MYSQL_DATABASE=slate \
#     -e MYSQL_USER=slate -e MYSQL_PASSWORD=slate \
#     mysql:8
DATABASE_URL=mysql://slate:slate@127.0.0.1:3306/slate

# Backend 监听端口
PORT=3001

# JWT secret,正式部署用 openssl rand -hex 64
JWT_SECRET=dev_only_change_in_production
JWT_EXPIRATION=7d

# Webhook API key,外部项目调 /api/v1/groups/:gid/frames/:seq/render 时带 X-Api-Key
WEBHOOK_API_KEY=dev_only_change_in_production

# Blob 存储目录(frame image + audio 二进制)
BLOB_DIR=./blobs

# 设备拉取轮询间隔(秒),下发给设备
DEVICE_POLL_INTERVAL_SECONDS=60

# CORS allow origin(前端 dev server)
CORS_ORIGIN=http://localhost:5173

# 运行环境(development | production | test)
NODE_ENV=development

# 日志级别(debug | info | warn | error)
LOG_LEVEL=info
