// slate data model
// User / Device / Group / Content
// 字段顺序约定: scalar 字段最后两个固定为 createdAt + updatedAt; relation 紧随其后。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum ContentKind {
  image
  dynamic

  @@map("content_kind")
}

enum ContentAudioStatus {
  none
  pending
  generating
  ready
  failed

  @@map("content_audio_status")
}

enum ContentAudioSource {
  upload
  tts

  @@map("content_audio_source")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String?  @unique @db.VarChar(32)
  password  String   @db.VarChar(255) // bcrypt hash
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  devices Device[] @relation("DeviceOwner")
  groups  Group[]  @relation("GroupOwner")

  @@map("users")
}

model Device {
  id               String    @id @default(cuid())
  // 设备身份指纹（eFuse MAC，重置时作为 Device 行的稳定锚点；不参与 HTTP 鉴权）
  mac              String    @unique @db.VarChar(17)
  // sha256(device_secret) hex；secret 明文仅在 register 响应里返回一次，丢了只能工厂重置
  secretHash       String    @unique(map: "devices_secret_hash_key") @map("secret_hash") @db.Char(64)
  // 6 位配对码；生成字母表为 A-Z 去 I/L/O + 2-9，降低屏幕抄码混淆
  pairCode         String    @unique @map("pair_code") @db.Char(6)
  name             String?   @db.VarChar(64)
  ownerUserId      String?   @map("owner_user_id")
  sortOrder        Int       @default(0) @map("sort_order")
  selectedGroupId  String?   @map("selected_group_id")
  lastRegisteredAt DateTime? @map("last_registered_at")
  lastSeenAt       DateTime? @map("last_seen_at")
  batteryPct       Int?      @map("battery_pct")
  rssiDbm          Int?      @map("rssi_dbm")
  fwVersion        String?   @map("fw_version") @db.VarChar(32)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  owner         User?  @relation("DeviceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  selectedGroup Group? @relation("DeviceSelectedGroup", fields: [selectedGroupId], references: [id], onDelete: SetNull)

  @@unique([ownerUserId, sortOrder], map: "devices_owner_user_id_sort_order_key")
  @@index([selectedGroupId])
  @@index([lastSeenAt])
  @@map("devices")
}

model Group {
  id            String   @id @default(cuid())
  name          String   @db.VarChar(64)
  structureEtag String   @default("empty") @map("structure_etag") @db.VarChar(64)
  manifestEtag  String   @default("empty") @map("manifest_etag") @db.VarChar(64)
  ownerUserId   String?  @map("owner_user_id")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  owner            User?     @relation("GroupOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  contents         Content[]
  selectingDevices Device[]  @relation("DeviceSelectedGroup")

  @@unique([ownerUserId, sortOrder], map: "groups_owner_user_id_sort_order_key")
  @@map("groups")
}

model Content {
  id                       String              @id @default(cuid())
  groupId                  String              @map("group_id")
  sortOrder                Int                 @map("sort_order") // group 内的位置序号；与 Device/Group 的 sortOrder 同义
  frameName                String?             @map("frame_name") @db.VarChar(64)
  contentEtag              String              @default("empty") @map("content_etag") @db.VarChar(64)
  imageEtag                String              @map("image_etag") @db.VarChar(64)
  audioEtag                String?             @map("audio_etag") @db.VarChar(64)
  imageSize                Int                 @map("image_size")
  audioSize                Int?                @map("audio_size")
  audioStatus              ContentAudioStatus  @default(none) @map("audio_status")
  audioSource              ContentAudioSource? @map("audio_source")
  audioVoice               String?             @map("audio_voice") @db.VarChar(32)
  audioText                String?             @map("audio_text") @db.VarChar(512)
  audioLastError           String?             @map("audio_last_error") @db.VarChar(512)
  audioUpdatedAt           DateTime?           @map("audio_updated_at")
  audioLeaseUntil          DateTime?           @map("audio_lease_until")
  audioAttempts            Int                 @default(0) @map("audio_attempts")
  // image = 用户上传图片；dynamic = 后端按 dynamicType+dynamicConfig 周期渲染。
  kind                     ContentKind         @default(image)
  // 仅 kind=dynamic 时有意义。dynamicType 对应 shared DynamicType。
  dynamicType              String?             @map("dynamic_type") @db.VarChar(32)
  dynamicConfig            Json?               @map("dynamic_config")
  dynamicData              Json?               @map("dynamic_data")
  dynamicLastRunAt         DateTime?           @map("dynamic_last_run_at")
  dynamicNextRunAt         DateTime?           @map("dynamic_next_run_at")
  dynamicRefreshDueAt      DateTime?           @map("dynamic_refresh_due_at")
  dynamicRefreshLeaseUntil DateTime?           @map("dynamic_refresh_lease_until")
  dynamicRefreshAttempts   Int                 @default(0) @map("dynamic_refresh_attempts")
  dynamicLastError         String?             @map("dynamic_last_error") @db.VarChar(512)
  createdAt                DateTime            @default(now()) @map("created_at")
  updatedAt                DateTime            @updatedAt @map("updated_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, sortOrder])
  @@index([groupId, kind])
  @@index([audioSource, audioStatus, audioLeaseUntil, audioUpdatedAt], map: "contents_audio_worker_idx")
  @@index([kind, dynamicRefreshDueAt, dynamicRefreshLeaseUntil], map: "contents_dynamic_refresh_worker_idx")
  @@index([kind, dynamicType])
  @@map("contents")
}
