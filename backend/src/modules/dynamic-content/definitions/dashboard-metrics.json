{
  "type": "dashboard",
  "default_ttl_sec": null,
  "layout": {
    "size": [400, 300],
    "padding": 20,
    "top_offset": 24,
    "body": [
      {
        "block": "text",
        "field": "data.subtitle",
        "size": 13,
        "font": "sans",
        "align": "left"
      },
      {
        "block": "key_value",
        "size": 22,
        "font": "mono",
        "items": [
          { "label": "今日", "field": "data.metrics.today" },
          { "label": "昨日", "field": "data.metrics.yesterday" },
          { "label": "本周", "field": "data.metrics.this_week" },
          { "label": "本月", "field": "data.metrics.this_month" }
        ]
      }
    ]
  }
}
