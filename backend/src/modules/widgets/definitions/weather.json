{
  "type": "weather",
  "default_ttl_sec": 600,
  "layout": {
    "size": [400, 300],
    "padding": 16,
    "top_offset": 24,
    "body": [
      {
        "block": "centered_text",
        "field": "data.summary",
        "size": 18,
        "font": "sans",
        "weight": "bold"
      },
      {
        "block": "big_number",
        "field": "data.tempC",
        "suffix": "°",
        "size": 72,
        "font": "mono"
      },
      { "block": "separator", "style": "dashed" },
      {
        "block": "key_value",
        "size": 14,
        "font": "sans",
        "items": [
          { "label": "湿度", "field": "data.humidity", "suffix": "%" },
          { "label": "风速", "field": "data.windDisplay" }
        ]
      },
      { "block": "separator", "style": "solid" },
      {
        "block": "key_value",
        "size": 14,
        "font": "sans",
        "items": [
          { "label_field": "data.fc.0.label", "field": "data.fc.0.val" },
          { "label_field": "data.fc.1.label", "field": "data.fc.1.val" },
          { "label_field": "data.fc.2.label", "field": "data.fc.2.val" }
        ]
      }
    ]
  }
}
