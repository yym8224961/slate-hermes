{
  "type": "date",
  "default_ttl_sec": 86400,
  "layout": {
    "size": [400, 300],
    "padding": 16,
    "top_offset": 24,
    "body": [
      {
        "block": "centered_text",
        "field": "data.year",
        "size": 14,
        "font": "sans"
      },
      {
        "block": "centered_text",
        "field": "data.weekdayCN",
        "size": 24,
        "font": "sans",
        "weight": "bold"
      },
      {
        "block": "centered_text",
        "field": "data.monthDay",
        "size": 90,
        "font": "mono",
        "weight": "bold"
      },
      { "block": "separator", "style": "dashed" },
      {
        "block": "centered_text",
        "field": "data.lunar",
        "size": 16,
        "font": "sans"
      },
      {
        "block": "centered_text",
        "field": "data.solarTerm",
        "size": 18,
        "font": "sans",
        "weight": "bold"
      }
    ]
  }
}
