# Docker 部署环境变量。
# 部署时把本文件复制为 compose.yml 同目录下的 .env。
# 本地后端开发请使用 backend/.env.example。

# 必填密钥。
MYSQL_PASSWORD=change_me
JWT_SECRET=change_me_at_least_32_chars

# 后端运行默认值。
NODE_ENV=production
LOG_LEVEL=info
PORT=3001
JWT_EXPIRATION=7d
BLOB_DIR=/data/blobs
BACKGROUND_WORKERS=true

# DATABASE_URL 由 compose.yml 根据 MYSQL_PASSWORD 自动生成：
# mysql://slate:<MYSQL_PASSWORD>@mysql:3306/slate
# compose 内置 MySQL 通常需要 true；外部生产 MySQL 建议配置 TLS 或固定服务端公钥后改为 false。
DB_ALLOW_PUBLIC_KEY_RETRIEVAL=true

# 天气动态帧。QWEATHER_API_HOST 必须包含 https://。
QWEATHER_API_KEY=
QWEATHER_API_HOST=

# 历史上的今天 AI 优化。
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=gpt-4o-mini

# 动态内容 TTS。
TTS_API_KEY=
TTS_BASE_URL=
TTS_MODEL=mimo-v2.5-tts
TTS_DEFAULT_VOICE=冰糖
